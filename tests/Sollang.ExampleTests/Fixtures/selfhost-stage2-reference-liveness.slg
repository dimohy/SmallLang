# A branch-selected nested indexed ref locks every overlapping owner place.
struct Inner {
    first: Int
}

struct Item {
    value: Int
}

struct Outer {
    right: Inner
    tail: Int
}

choose condition: Bool, left: ref Int, right: ref Int -> ref Int {
    condition -> if {
        left -> return
    }
    right
}

read value: ref Int -> Int {
    value
}

main {
    Outer {
        right: Inner { first: 51 }
        tail: 61
    } => outer!
    [Item { value: 41 }, Item { value: 42 }, ~] => items!
    choose(true, items![0].value, outer!.right.first) => borrowed
    Item { value: 43 } => items![0]
    borrowed -> read => observed
    "$(observed)" -> println
}
