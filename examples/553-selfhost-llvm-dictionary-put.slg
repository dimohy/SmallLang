import sollang.compiler.llvm.text as llvm

# Verifies self-host LLVM dictionary insertion and update for Int keys/values.
main {
    [
        """
        main {
            { 1: 10, 2: 20 } => scores!
            scores! -> put(3, 30)
            scores! -> put(2, 222)
            scores![3] == 30 -> if { "30" -> println }
            scores![2] == 222 -> if { "222" -> println }
        }
        """,
        ~,
    ] => sources!
    sources! -> llvm.emit
}
