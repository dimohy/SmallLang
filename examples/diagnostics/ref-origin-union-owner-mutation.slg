# Every owner selected by a branch remains locked while the returned ref is live.
struct Pair {
    first: Int
}

choose condition: Bool, left: ref Pair, right: ref Pair -> ref Pair {
    condition -> if {
        left -> return
    }
    right
}

read pair: ref Pair -> Int {
    pair.first
}

main {
    Pair { first: 11 } => left!
    Pair { first: 21 } => right!
    choose(true, left!, right!) => borrowed
    22 => right!.first
    borrowed -> read -> println
}
