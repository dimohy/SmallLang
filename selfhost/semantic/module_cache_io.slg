namespace sollang.compiler.semantic.module_cache_io

import sys.file as file

writeSucceeded result: Result<Unit, Text> -> Bool => result -> when {
    Ok(_) { true }
    Err(_) { false }
}

readWord result: Result<Option<UInt64>, Text> -> Option<UInt64> => result -> when {
    Ok(value) { value }
    Err(_) { Option<UInt64>.None }
}

hasWord word: Option<UInt64> -> Bool => word -> when {
    Some(_) { true }
    None { false }
}

zeroWord: -> UInt64 => UInt64(0)

wordValue word: Option<UInt64> -> UInt64 => word -> when {
    Some(value) { value }
    None { zeroWord }
}

writeStaged path: Text, words: [UInt64; ~] -> Bool uses File {
    file.openWrite(path) -> when {
        Ok(writer) {
            true => valid!
            0 => index!
            (valid! and index! < (words -> len)) -> while {
                writer -> writeAt<UInt64>(words[index!], UInt64(index!) * UInt64(8)) => writeResult
                writeResult -> writeSucceeded => valid!
                index! + 1 => index!
            }
            valid! -> if { writer -> file.sync => valid! }
            valid!
        }
        Err(_) { false }
    }
}

public publish words: [UInt64; ~], destination: Text, temporary: Text -> Bool uses File {
    temporary -> writeStaged(words) => staged
    staged -> if {
        file.AtomicReplaceRequest {
            temporary: temporary
            destination: destination
        } -> file.atomicReplace
    } else { false }
}

public load path: Text -> [UInt64; ~] uses File {
    [UInt64; ~] => words!
    file.openRead(path) -> when {
        Ok(reader) {
            true => valid!
            0 => index!
            (valid! and index! < 6) -> while {
                reader -> readAt<UInt64>(UInt64(index!) * UInt64(8)) => readResult
                readResult -> readWord => word
                word -> hasWord => valid!
                valid! -> if {
                    word -> wordValue => value
                    words! -> push(value)
                }
                index! + 1 => index!
            }
            0 => wordCount!
            valid! -> if {
                words![4] >= UInt64(7) and words![4] <= UInt64(16000000) -> if {
                    Int(words![4]) => wordCount!
                } else { false => valid! }
            }
            (valid! and index! < wordCount!) -> while {
                reader -> readAt<UInt64>(UInt64(index!) * UInt64(8)) => readResult
                readResult -> readWord => word
                word -> hasWord => valid!
                valid! -> if {
                    word -> wordValue => value
                    words! -> push(value)
                }
                index! + 1 => index!
            }
        }
        Err(_) {}
    }
    words!
}
